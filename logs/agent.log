hedule\\n      Schedule Type Limits Name: Fraction\\n      Data:\\n        - Through: \\\"12/31\\\"\\n          Days:\\n          - For: Weekdays\\n            Times:\\n            - Until:\\n                Time: \\\"08:00\\\"\\n                Value: 0.05\\n            - Until:\\n                Time: \\\"22:00\\\"\\n                Value: 0.95\\n            - Until:\\n                Time: \\\"24:00\\\"\\n                Value: 0.05\\n          - For: Saturday\\n            Times:\\n            - Until:\\n                Time: \\\"08:00\\\"\\n                Value: 0.05\\n            - Until:\\n                Time: \\\"22:00\\\"\\n                Value: 0.50\\n            - Until:\\n                Time: \\\"24:00\\\"\\n                Value: 0.05\\n          - For: AllOtherDays\\n            Times:\\n            - Until:\\n                Time: \\\"24:00\\\"\\n                Value: 0.0\\n\\n    # Lighting schedule: same profile as occupancy\\n    - Name: Lighting_Schedule\\n      Schedule Type Limits Name: Fraction\\n      Data:\\n        - Through: \\\"12/31\\\"\\n          Days:\\n          - For: Weekdays\\n            Times:\\n            - Until:\\n                Time: \\\"08:00\\\"\\n                Value: 0.05\\n            - Until:\\n                Time: \\\"22:00\\\"\\n                Value: 0.90\\n            - Until:\\n                Time: \\\"24:00\\\"\\n                Value: 0.05\\n          - For: Saturday\\n            Times:\\n            - Until:\\n                Time: \\\"08:00\\\"\\n                Value: 0.05\\n            - Until:\\n                Time: \\\"22:00\\\"\\n                Value: 0.50\\n            - Until:\\n                Time: \\\"24:00\\\"\\n                Value: 0.05\\n          - For: AllOtherDays\\n            Times:\\n            - Until:\\n                Time: \\\"24:00\\\"\\n                Value: 0.0\\n\\n    # Equipment schedule: same as occupancy\\n    - Name: Equipment_Schedule\\n      Schedule Type Limit