!- Windows Line endings 

VERSION,
    25.1.0;                   !- Version Identifier

SIMULATIONCONTROL,
    No,                       !- Do Zone Sizing Calculation
    No,                       !- Do System Sizing Calculation
    No,                       !- Do Plant Sizing Calculation
    No,                       !- Run Simulation for Sizing Periods
    Yes,                      !- Run Simulation for Weather File Run Periods
    Yes,                      !- Do HVAC Sizing Simulation for Sizing Periods
    1;                        !- Maximum Number of HVAC Sizing Simulation Passes

BUILDING,
    Office,                   !- Name
    0,                        !- North Axis
    Suburbs,                  !- Terrain
    0.04,                     !- Loads Convergence Tolerance Value
    0.4,                      !- Temperature Convergence Tolerance Value
    FullInteriorAndExterior,    !- Solar Distribution
    25,                       !- Maximum Number of Warmup Days
    6;                        !- Minimum Number of Warmup Days

SITE:LOCATION,
    Beijing_BJ_CHN Design_Conditions,    !- Name
    39.92,                    !- Latitude
    116.46,                   !- Longitude
    8,                        !- Time Zone
    44,                       !- Elevation
    No;                       !- Keep Site Location Information

RUNPERIOD,
    Run Period 1,             !- Name
    1,                        !- Begin Month
    1,                        !- Begin Day of Month
    2024,                     !- Begin Year
    12,                       !- End Month
    31,                       !- End Day of Month
    2024,                     !- End Year
    Monday,                   !- Day of Week for Start Day
    Yes,                      !- Use Weather File Holidays and Special Days
    Yes,                      !- Use Weather File Daylight Saving Period
    No,                       !- Apply Weekend Holiday Rule
    Yes,                      !- Use Weather File Rain Indicators
    Yes,                      !- Use Weather File Snow Indicators
    No,                       !- Treat Weather as Actual
    Hour24;                   !- First Hour Interpolation Starting Values

MATERIAL,
    Concrete_20cm,            !- Name
    MediumRough,              !- Roughness
    0.2,                      !- Thickness
    1.73,                     !- Conductivity
    2300,                     !- Density
    880,                      !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL,
    Gypsum_1.3cm,             !- Name
    Smooth,                   !- Roughness
    0.0127,                   !- Thickness
    0.16,                     !- Conductivity
    785,                      !- Density
    830,                      !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL:NOMASS,
    EPS_Insulation,           !- Name
    MediumRough,              !- Roughness
    1.71,                     !- Thermal Resistance
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL:AIRGAP,
    Roof_AirGap,              !- Name
    0.18;                     !- Thermal Resistance

WINDOWMATERIAL:SIMPLEGLAZINGSYSTEM,
    SimpleGlazingSystem,      !- Name
    1.8,                      !- UFactor
    0.52,                     !- Solar Heat Gain Coefficient
    0.65;                     !- Visible Transmittance

CONSTRUCTION,
    Exterior_Wall_Const,      !- Name
    Concrete_20cm,            !- Outside Layer
    EPS_Insulation;           !- Layer 2

CONSTRUCTION,
    Interior_Wall_Const,      !- Name
    Gypsum_1.3cm,             !- Outside Layer
    Gypsum_1.3cm;             !- Layer 2

CONSTRUCTION,
    Roof_Const,               !- Name
    Concrete_20cm,            !- Outside Layer
    Roof_AirGap,              !- Layer 2
    EPS_Insulation;           !- Layer 3

CONSTRUCTION,
    Floor_Const,              !- Name
    Concrete_20cm,            !- Outside Layer
    EPS_Insulation;           !- Layer 2

CONSTRUCTION,
    Ceiling_Const,            !- Name
    Gypsum_1.3cm,             !- Outside Layer
    Gypsum_1.3cm;             !- Layer 2

CONSTRUCTION,
    Window_Const,             !- Name
    SimpleGlazingSystem;      !- Outside Layer

GLOBALGEOMETRYRULES,
    UpperLeftCorner,          !- Starting Vertex Position
    Counterclockwise,         !- Vertex Entry Direction
    World,                    !- Coordinate System
    Relative,                 !- Daylighting Reference Point Coordinate System
    Relative;                 !- Rectangular Surface Coordinate System

